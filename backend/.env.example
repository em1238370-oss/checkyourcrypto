# Copy this file to .env and fill in the real credentials.
PORT=4000
FREE_TRIAL_HOURS=24
SUBSCRIPTION_PRICE_USD=10
SUBSCRIPTION_PERIOD_DAYS=30
APP_BASE_URL=http://localhost:4000

# Mistral AI
MISTRAL_API_KEY=mistral_api_key_here

# CryptoCloud crypto payments
CRYPTOCLOUD_API_KEY=your_cryptocloud_api_key
CRYPTOCLOUD_SHOP_ID=your_cryptocloud_shop_id

# CloudPayments card payments
CLOUDPAYMENTS_PUBLIC_ID=your_cloudpayments_public_id
CLOUDPAYMENTS_API_SECRET=your_cloudpayments_api_secret

